{
    "name": "bitexpert/sylius-product-document-plugin",
    "type": "sylius-plugin",
    "description": "Product document plugin for Sylius.",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "test-appication"
    ],
    "authors": [
        {
            "name": "Simon Krull",
            "email": "S.Krull@bitexpert.de",
            "homepage": "https://www.bitexpert.de"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "sylius/sylius": "^2.0"
    },
    "require-dev": {
        "behat/behat": "^3.16",
        "bitexpert/phpstan-sylius": "^0.3.0",
        "dbrekelmans/bdi": "^1.4",
        "dmore/behat-chrome-extension": "^1.4",
        "dmore/chrome-mink-driver": "^2.9",
        "friends-of-behat/mink": "^1.11",
        "friends-of-behat/mink-browserkit-driver": "^1.6",
        "friends-of-behat/mink-debug-extension": "^2.1",
        "friends-of-behat/mink-extension": "^2.7",
        "friends-of-behat/page-object-extension": "^0.3",
        "friends-of-behat/suite-settings-extension": "^1.1",
        "friends-of-behat/symfony-extension": "^2.6",
        "friends-of-behat/variadic-extension": "^1.6",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "phpunit/phpunit": "^10.5",
        "sylius-labs/coding-standard": "^4.4",
        "sylius-labs/suite-tags-extension": "~0.2",
        "sylius/sylius-rector": "^3.7",
        "sylius/test-application": "^2.0.0@alpha",
        "symfony/browser-kit": "^6.4 || ^7.4",
        "symfony/debug-bundle": "^6.4 || ^7.4",
        "symfony/dotenv": "^6.4 || ^7.4",
        "symfony/http-client": "^6.4 || ^7.4",
        "symfony/intl": "^6.4 || ^7.4",
        "symfony/maker-bundle": "^1.67",
        "symfony/runtime": "^6.4 || ^7.4",
        "symfony/web-profiler-bundle": "^6.4 || ^7.4",
        "symfony/webpack-encore-bundle": "^2.2"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "php-http/discovery": false,
            "phpstan/extension-installer": true,
            "rector/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0-dev"
        },
        "symfony": {
            "require": "^7.4"
        },
        "public-dir": "vendor/sylius/test-application/public"
    },
    "autoload": {
        "psr-4": {
            "BitExpert\\SyliusProductDocumentPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\BitExpert\\SyliusProductDocumentPlugin\\": ["tests/", "tests/TestApplication/src/"]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php bin/validate-directory.php"
        ],
        "post-create-project-cmd": [
            "@php bin/rename-plugin.php",
            "@test-app-init",
            "@php bin/show-success.php"
        ],
        "database-reset": [
            "vendor/bin/console doctrine:database:drop --force --if-exists",
            "vendor/bin/console doctrine:database:create",
            "vendor/bin/console doctrine:migration:migrate -n",
            "vendor/bin/console sylius:fixtures:load -n"
        ],
        "frontend-clear": [
            "cd vendor/sylius/test-application && yarn install && yarn build",
            "vendor/bin/console assets:install"
        ],
        "test-app-init": [
            "@database-reset",
            "@frontend-clear"
        ]
    }
}
